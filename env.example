# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App Configuration
NEXT_PUBLIC_CLUB_NAME=Smashers Club
NEXT_PUBLIC_BOOKING_COST=4

# ELO Grade Thresholds
NEXT_PUBLIC_ELO_GRADE_A=1600
NEXT_PUBLIC_ELO_GRADE_B=1400
NEXT_PUBLIC_ELO_GRADE_C=1200

# PWA - Push Notifications (Generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Cron Job Authentication
CRON_SECRET=your-secure-random-string

# Multi-club (Optional)
NEXT_PUBLIC_CLUB_ID=
